{
    "expo": {
        "name": "mobile-web-notes-app",
        "slug": "mobile-web-notes-app",
        "scheme": "mobilewebnotesapp",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./assets/splash/splash-logo-light.png",
            "resizeMode": "contain",
            "backgroundColor": "#f8fafc",
            "dark": {
                "image": "./assets/splash/splash-logo-dark.png",
                "backgroundColor": "#0f172a"
            }
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.anonymous.mobile-web-notes-app"
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#E6F4FE",
                "foregroundImage": "./assets/android-icon-foreground.png",
                "backgroundImage": "./assets/android-icon-background.png",
                "monochromeImage": "./assets/android-icon-monochrome.png"
            },
            "predictiveBackGestureEnabled": false,
            "package": "com.anonymous.mobilewebnotesapp"
        },
        "web": {
            "favicon": "./assets/favicon.png"
        },
        "plugins": ["expo-router", "expo-dev-client"]
    }
}
